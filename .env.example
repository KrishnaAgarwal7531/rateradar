TINYFISH_API_KEY=your_tinyfish_key_here
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CRON_SECRET=any_random_string

# Optional — lets the "Refresh rates now" button dispatch the GitHub
# Actions workflow instead of running inline on Vercel (avoids Vercel's
# function duration limit). Without these two set, the button falls back
# to running inline, which works but risks timing out on Vercel Hobby.
GITHUB_TOKEN=personal_access_token_with_workflow_scope
GITHUB_REPO=yourname/rateradar
